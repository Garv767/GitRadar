# GitRadar Environment Configuration Template
# Copy this file to '.env' and adjust configurations as needed.

# The port the Express application server will bind to
PORT=5000

# Unified Database Connection URI
# Supports automatic detection of Postgres or MySQL dialect
#
# Examples:
# - PostgreSQL/Neon: postgresql://user:password@ep-snowflake.us-east-2.aws.neon.tech/neondb?sslmode=require
# - MySQL Local: mysql://root:password@127.0.0.1:3306/gitradar
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

# GitHub Personal Access Token (Optional but highly recommended)
# Used to bypass default API rate limits (60 req/hr -> 5000 req/hr)
# GITHUB_TOKEN=your_github_personal_access_token_here

# GitHub OAuth App credentials (required for user sign-in via GitHub)
# GITHUB_CLIENT_ID=your_github_client_id_here
# GITHUB_CLIENT_SECRET=your_github_client_secret_here
